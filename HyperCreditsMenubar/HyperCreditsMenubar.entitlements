<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Deliberately not sandboxed. Reading Claude Code's usage limits means reading the
  credentials Claude Code owns: its login-Keychain item (via /usr/bin/security) and
  ~/.claude/.credentials.json. A sandboxed app can spawn neither the process nor read
  a file outside its container, so the sandbox and the feature are mutually exclusive.
  The app ships ad-hoc signed through Homebrew rather than through the App Store, where
  the sandbox would be mandatory.
-->
<plist version="1.0">
<dict>
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
